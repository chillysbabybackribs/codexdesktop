{
  // Biome editor integration. Fixes/formatting apply inline as you edit — the same
  // live experience Cursor gives you. Uses biome.jsonc as the source of truth, so
  // a11y stays off here too; only real-bug rules surface inline.
  "editor.defaultFormatter": "biomejs.biome",
  "editor.formatOnSave": true,
  // Only reformat the lines you actually changed — never a whole-file rewrite that
  // would bury your real diff. Falls back to full-file only when git isn't available.
  "editor.formatOnSaveMode": "modificationsIfAvailable",
  "editor.codeActionsOnSave": {
    // Apply Biome's SAFE lint auto-fixes on save (unused imports, const, etc.).
    "quickfix.biome": "explicit",
    // Import reordering stays off to match biome.jsonc and avoid churn.
    "source.organizeImports.biome": "never"
  },
  "[typescript]": { "editor.defaultFormatter": "biomejs.biome" },
  "[typescriptreact]": { "editor.defaultFormatter": "biomejs.biome" },
  "[javascript]": { "editor.defaultFormatter": "biomejs.biome" },
  "[json]": { "editor.defaultFormatter": "biomejs.biome" },
  "[jsonc]": { "editor.defaultFormatter": "biomejs.biome" }
}
