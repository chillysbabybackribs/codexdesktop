{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Studio Hunt Phase 0 Record",
  "type": "object",
  "required": ["recordId", "source", "url", "observedAt", "sourceLane", "retrievalStatus", "actorType", "statementType", "firsthand", "independenceKey"],
  "properties": {
    "recordId": {"type": "string"},
    "source": {"type": "string"},
    "url": {"type": "string"},
    "observedAt": {"type": "string"},
    "publishedAt": {"type": ["string", "null"]},
    "window": {"type": ["string", "null"]},
    "sourceLane": {"enum": ["commercial_motion", "formation_feedback", "buyer_reality", "catalyst"]},
    "retrievalStatus": {"enum": ["verified", "discovered", "blocked", "thin", "duplicate", "stale"]},
    "actorType": {"enum": ["buyer_operator", "service_provider", "startup_founder", "competitor_vendor", "enthusiast_nonbuyer", "unknown"]},
    "actorEvidence": {"type": ["string", "null"]},
    "statementType": {"enum": ["own_workflow", "own_purchase", "own_workaround", "own_implementation", "feature_request", "product_pitch", "market_opinion", "promotion", "secondhand_claim", "unknown"]},
    "firsthand": {"type": "boolean"},
    "startupName": {"type": ["string", "null"]},
    "productDomain": {"type": ["string", "null"]},
    "founderHandle": {"type": ["string", "null"]},
    "buyer": {"type": ["string", "null"]},
    "trigger": {"type": ["string", "null"]},
    "input": {"type": ["string", "null"]},
    "repeatedAction": {"type": ["string", "null"]},
    "output": {"type": ["string", "null"]},
    "destination": {"type": ["string", "null"]},
    "frequency": {"type": ["string", "null"]},
    "timeSpent": {"type": ["string", "null"]},
    "priceOrWage": {"type": ["string", "null"]},
    "commercialMetric": {"type": ["object", "null"]},
    "metricPeriod": {"type": ["string", "null"]},
    "currentTools": {"type": "array", "items": {"type": "string"}},
    "remainingManualWork": {"type": ["string", "null"]},
    "objection": {"type": ["string", "null"]},
    "requestedOutcome": {"type": ["string", "null"]},
    "textExcerpt": {"type": ["string", "null"]},
    "artifactPath": {"type": ["string", "null"]},
    "independenceKey": {"type": "string"},
    "commercialStrength": {"enum": ["none", "weak", "medium", "strong"]},
    "classificationConfidence": {"enum": ["low", "medium", "high"]},
    "classificationReason": {"type": ["string", "null"]},
    "moneyType": {"enum": ["none", "currency_mention", "adjacent_spend", "revenue_or_valuation", "hypothetical", "exact_job_spend", "exact_job_wage"]},
    "caveat": {"type": ["string", "null"]}
  }
}
