{
  "name": "codexdesktop",
  "version": "0.1.0",
  "description": "Codex Desktop chat with an embedded Chromium browser.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "node scripts/dev-with-autogit.mjs",
    "dev:app": "electron-vite dev",
    "git:autosnapshot": "node scripts/git-autosnapshot.mjs --watch",
    "git:autosnapshot:once": "node scripts/git-autosnapshot.mjs --once",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "node --experimental-strip-types --loader ./scripts/test-loader.mjs --test src/main/browser/*.test.ts",
    "gen:codex-protocol": "codex app-server generate-ts --experimental --out src/shared/codex-protocol"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0"
  },
  "devDependencies": {
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^43.1.0",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  }
}
