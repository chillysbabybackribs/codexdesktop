{
  "name": "codexdesktop",
  "version": "0.1.0",
  "description": "Codex Desktop chat with an embedded Chromium browser.",
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "predev": "npm run clean:source-shadows",
    "dev": "node scripts/dev-with-autogit.mjs",
    "predev:app": "npm run clean:source-shadows",
    "dev:app": "electron-vite dev",
    "verify:app": "npm run build && node scripts/verify-instance.mjs",
    "git:autosnapshot": "node scripts/git-autosnapshot.mjs --watch",
    "git:autosnapshot:once": "node scripts/git-autosnapshot.mjs --once",
    "prebuild": "npm run clean:source-shadows",
    "build": "npm run typecheck && electron-vite build",
    "preview": "electron-vite preview",
    "pretypecheck": "npm run check:source-shadows",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "pretest": "npm run check:source-shadows",
    "test": "node --experimental-strip-types --loader ./scripts/test-loader.mjs --test src/main/*.test.ts src/main/agents/*.test.ts src/main/browser/*.test.ts src/main/codex/*.test.ts src/main/providers/*.test.ts src/renderer/src/*.test.ts",
    "fetch:tor": "node scripts/fetch-tor.mjs",
    "benchmark:tokens": "node scripts/token-baseline.mjs",
    "benchmark:browser": "node --no-warnings --experimental-strip-types --loader ./scripts/test-loader.mjs scripts/browser-eval.mjs",
    "clean:source-shadows": "node scripts/source-shadow-guard.mjs --fix",
    "check:source-shadows": "node scripts/source-shadow-guard.mjs --check",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "lint:strict": "biome lint --config-path=biome.strict.jsonc",
    "format": "biome format --write",
    "check": "biome check",
    "check:fix": "biome check --write",
    "gen:codex-protocol": "codex app-server generate-ts --experimental --out src/shared/codex-protocol"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "0.3.215",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@fontsource-variable/inter": "^5.3.0",
    "ai": "^7.0.31",
    "linkedom": "^0.18.13",
    "lucide-react": "^1.25.0",
    "nanoid": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@types/node": "^24.10.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^43.1.0",
    "electron-vite": "^5.0.0",
    "typescript": "^7.0.2",
    "vite": "^7.3.6"
  }
}
