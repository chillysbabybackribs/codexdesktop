node_modules/
out/
dist/
release/
.vite/

# Compiled output from the composite tsconfig can land next to sources in src/
# and (because imports resolve `.js`) silently shadow the real .ts at bundle
# time. Never track these; the codex-protocol dir is generated *source* and is
# the one exception.
src/main/**/*.js
src/main/**/*.d.ts
src/preload/**/*.js
src/preload/**/*.d.ts
src/shared/*.js
src/shared/*.d.ts

*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

.env
.env.*
!.env.example

.DS_Store
Thumbs.db
node_modules
electron.vite.config.js
electron.vite.config.d.ts
