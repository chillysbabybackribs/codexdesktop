{
  "$schema": "https://biomejs.dev/schemas/2.5.4/schema.json",
  // FINAL-PHASE ruleset. Same as biome.jsonc but with a11y turned back ON.
  // NOT used by `npm run lint`; run `npm run lint:strict` during accessibility/
  // security hardening to surface the deferred a11y findings.
  "extends": ["./biome.jsonc"],
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "a11y": "on"
    }
  }
}
